# Supabase public client configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Public admin email used for Supabase Auth sign-in.
# Create this user manually in Supabase Auth and set its password/access code there.
NEXT_PUBLIC_WAYLUZ_ADMIN_EMAIL=admin@wayluz.com

# Keep diagnostics disabled in production.
NEXT_PUBLIC_ENABLE_DIAGNOSTICS=false

# Optional server-only key for API routes. Do not expose this in browser code.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
