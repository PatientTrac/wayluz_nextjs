NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY

# Optional compatibility aliases. Do not use secret/service-role values here.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY

# Server-only. Never put this in NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_WAYLUZ_ADMIN_EMAIL=admin@wayluz.com
NEXT_PUBLIC_ENABLE_DIAGNOSTICS=false

# --- Contact form email (Resend) ---
# Required for the auto-reply + sales lead email to actually send.
RESEND_API_KEY=re_your_key_here
# Sender must be on a domain verified in your Resend account.
WAYLUZ_FROM_EMAIL=WayLuz <noreply@wayluz.com>
WAYLUZ_SALES_EMAIL=sales@wayluz.com
WAYLUZ_PROPERTIES_URL=https://wayluz.com/properties

# --- Email (Resend) — used by /api/contact AND the WhatsApp auto-reply --------
RESEND_API_KEY=re_your_key
WAYLUZ_SALES_EMAIL=sales@wayluz.com
# FROM must be on a domain you've verified in Resend:
WAYLUZ_FROM_EMAIL=WayLuz <noreply@wayluz.com>
WAYLUZ_PROPERTIES_URL=https://wayluz.com/properties

# --- WhatsApp auto-reply ------------------------------------------------------
WA_AUTOREPLY_ENABLED=true
# Optional: override the default bilingual (ES/EN) first-contact reply.
# WA_AUTOREPLY_TEXT=
