# ---- WhatsApp Cloud API (per project — these are unique to each project's number) ----
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=          # Meta "Phone Number ID" (from WhatsApp > API Setup)
WHATSAPP_TOKEN=                    # system-user token, scope: whatsapp_business_messaging
WHATSAPP_VERIFY_TOKEN=            # any long random string; you also type it into Meta's webhook config
WHATSAPP_APP_SECRET=               # Meta App > Settings > Basic > App Secret (verifies inbound)

# ---- Inbox send-route guard ----
INBOX_API_SECRET=                  # shared secret the UI sends as x-inbox-secret (stop-gap auth)

# ---- Supabase (WayLuz already has these — reuse them) ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=         # server only; never expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
