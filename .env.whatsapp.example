# WhatsApp inbox config. Most fields are admin-managed in the DB (/inbox/settings),
# so these env vars are OPTIONAL fallbacks. REQUIRED no matter what: the
# encryption key + the Supabase keys.

# ---- Required ----
WHATSAPP_CONFIG_KEY=               # strong random string; encrypts the DB-stored Auth Token. Generate: openssl rand -hex 32
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=         # server only; never expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Optional Twilio fallbacks (set these OR enter them in /inbox/settings) ----
TWILIO_ACCOUNT_SID=                # AC...
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=              # +14246224568

# --- Stage 3: DeepL translation (optional) ---
# Get a key at https://www.deepl.com/pro-api (free tier is fine).
# Free-tier keys end with ':fx'. If unset, translation is disabled and the
# inbox shows original text only.
DEEPL_API_KEY=
# Customer language (outbound target) and agent language (inbound target).
# Defaults: ES customer, EN-US agent.
WA_CUSTOMER_LANG=ES
WA_ADMIN_LANG=EN-US
