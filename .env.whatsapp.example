# Now that config is admin-managed in the DB, most of these are OPTIONAL fallbacks.
# REQUIRED no matter what: the encryption key + Supabase keys.

# ---- Required ----
WHATSAPP_CONFIG_KEY=               # strong random string; encrypts DB-stored secrets. Generate: openssl rand -hex 32
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=         # server only; never expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Optional env fallbacks (set these OR enter them in /inbox/settings) ----
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
